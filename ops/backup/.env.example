# Dimissio Backup — host .env template
#
# Copy to /opt/dimissio-backup/.env on the Hetzner host and fill in.
# Protect with: chmod 600 .env && chown root:root .env
# NEVER commit the populated .env — ops/backup/.env is gitignored.

# ---------------------------------------------------------------------------
# Postgres (running in Docker on the same host)
# ---------------------------------------------------------------------------

# The Docker container name or ID of the Postgres instance. Coolify-generated
# IDs are stable across redeploys of the same resource. Check with:
#   docker ps --format '{{.Names}}' | grep postgres
POSTGRES_CONTAINER=u66tldai3f6ph1e5b7rco2dd

# Postgres superuser used for pg_dump / pg_restore / createdb / dropdb.
POSTGRES_USER=postgres

# Database to dump.
POSTGRES_DB=postgres

# ---------------------------------------------------------------------------
# GPG
# ---------------------------------------------------------------------------

# Recipient for gpg --encrypt. Must match a public key imported into the
# host's root keyring. Either the key's email (e.g. backup@dimissio.eu) or
# its long key-ID / fingerprint. The private key lives ONLY in 1Password.
GPG_RECIPIENT=

# ---------------------------------------------------------------------------
# rclone
# ---------------------------------------------------------------------------

# Remote name (as configured via `rclone config`) plus base path.
# Expected layout on the remote:
#   <remote>/daily/    — rolling 30 days
#   <remote>/monthly/  — rolling 12 months
RCLONE_REMOTE=hetzner:dimissio-backups

# ---------------------------------------------------------------------------
# Telegram alerts
# ---------------------------------------------------------------------------

# Same token/chat-id pair as the app uses. Duplicated here deliberately so
# the backup script has no runtime dependency on the Node app.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
